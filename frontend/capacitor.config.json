{
  "appId": "com.borsakrali.app",
  "appName": "Borsa Krali",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "borsakrali.com",
      "*.borsakrali.com",
      "localhost"
    ]
  },
  "android": {
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": true,
    "minWebViewVersion": 60
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#0a0a0f",
      "overlaysWebView": false
    },
    "EdgeToEdge": {
      "backgroundColor": "#0a0a0f"
    }
  }
}
