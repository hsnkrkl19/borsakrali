# Server Configuration
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=borsasanati
DB_USER=borsauser
DB_PASSWORD=your_secure_password_here
DB_DIALECT=postgres
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d
AUTH_ENCRYPTION_SECRET=change_this_for_encrypted_user_store
ADMIN_EMAILS=admin@example.com

# Public URLs
PUBLIC_SITE_URL=https://borsakrali.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id

# Firebase Cloud Messaging
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}
FIREBASE_SERVICE_ACCOUNT_BASE64=
FCM_BROADCAST_TOPIC=borsakrali-all-users
FCM_DEFAULT_CHANNEL_ID=borsa-krali-announcements

# Redis (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Yahoo Finance
# No API key needed for basic usage
YAHOO_FINANCE_TIMEOUT=30000

# KAP (Kamuyu Aydınlatma Platformu)
KAP_BASE_URL=https://www.kap.org.tr
KAP_API_URL=https://www.kap.org.tr/tr/api

# External APIs (Optional)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FINNHUB_API_KEY=your_finnhub_key

# Cron Jobs
ENABLE_CRON_JOBS=true
MARKET_DATA_CRON=*/5 * * * *
NEWS_SCRAPER_CRON=*/15 * * * *
CALCULATION_CRON=0 */1 * * *

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# CORS
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Frontend URL (for emails, etc.)
FRONTEND_URL=http://localhost:3000
