{
  "name": "borsasanati-backend",
  "version": "1.0.0",
  "description": "Borsa Sanatı Backend API - AI Powered Stock Analysis Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server-live.js",
    "dev": "nodemon src/server-live.js",
    "start:mock": "node src/server-mock.js",
    "dev:mock": "nodemon src/server-mock.js",
    "start:db": "node src/server.js",
    "dev:db": "nodemon src/server.js",
    "test": "jest --coverage",
    "migrate": "sequelize-cli db:migrate",
    "seed": "sequelize-cli db:seed:all",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "stock",
    "trading",
    "ai",
    "analysis",
    "bist"
  ],
  "author": "Borsa Sanatı Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.5",
    "axios-cookiejar-support": "^6.0.5",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fast-xml-parser": "^4.3.4",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.64.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "redis": "^4.6.12",
    "sequelize": "^6.35.2",
    "socket.io": "^4.8.3",
    "tough-cookie": "^6.0.0",
    "winston": "^3.11.0",
    "yahoo-finance2": "^2.14.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
